# 환경 (local | staging | prod). 1주차는 local 고정.
ENV=local

# 대상 웹앱
TARGET_URL=http://localhost:3000
LOGIN_URL=http://localhost:3000/auth/login

# 테스트 계정 (슈퍼 계정: ROLE_SYSTEM_ADMIN)
TEST_EMAIL=facility@airport.co.kr
TEST_PASSWORD=

# Anthropic
# Max/Pro plan 사용자는 비워둬도 된다. Claude Code CLI(`claude`) OAuth 자격증명을 자동 사용한다.
# Console 결제(API key) 사용자만 발급받은 키를 채워라.
ANTHROPIC_API_KEY=

# 모델/토큰 상한은 단계별로 src/stages/config.ts 에서 관리한다 (1주차 모두 Opus 4.7 단일).

# ───── 시드 데이터 가정 (선택) ─────
# tests-generated/management-logs.spec.ts 가 사용하는 변수.
# 미설정 시 1주차 baseline 값(73 / KPI_DATA_MISSING)이 쓰인다.
# 시드 환경이 다르면 docs/seed-assumptions.md 참고하여 채워라.
SEED_LOG_COUNT=
SEED_LOG_KEYWORD=
