{
  "name": "cartographer",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous E2E test generation agent (Week 1: single-agent baseline)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "sanity": "tsx src/index.ts --sanity",
    "dry-run": "DRY_RUN=true tsx src/index.ts",
    "start": "tsx src/index.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.122",
    "dotenv": "^16.4.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.71",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
